{
  "hooks": {
    "WorktreeCreate": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${PLUGIN_ROOT:-$CLAUDE_PLUGIN_ROOT}/skills/setup/setup-worktree.sh\"",
            "timeout": 30
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash:git",
        "hooks": [
          {
            "type": "command",
            "command": "\"${PLUGIN_ROOT:-$CLAUDE_PLUGIN_ROOT}/hooks/commit-guard.sh\""
          }
        ]
      }
    ]
  }
}
