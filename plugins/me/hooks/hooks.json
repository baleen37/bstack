{
  "description": "Everything Agent - unified hooks for all features",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": []
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash:git",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/commit-guard.sh"
          }
        ]
      }
    ]
  }
}
